# Server Base (Protocol + Domain + Port)
VITE_BACKEND_URL=https://api.marigold.co.kr

# API V1 Base (Used by Axios)
VITE_API_V1_BASE=https://api.marigold.co.kr/api/v1

# OAuth2 Endpoints
VITE_API_OAUTH2_KAKAO=https://api.marigold.co.kr/oauth2/authorization/kakao
VITE_API_OAUTH2_NAVER=https://api.marigold.co.kr/oauth2/authorization/naver